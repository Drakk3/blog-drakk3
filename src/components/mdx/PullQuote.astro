---
interface Props {
  author?: string;
}
const { author } = Astro.props;
---
<blockquote class="not-prose my-10 border-l-4 border-zinc-800 pl-6 dark:border-zinc-200">
  <p class="font-serif text-xl font-medium leading-relaxed text-zinc-800 dark:text-zinc-200 md:text-2xl">
    <slot />
  </p>
  {author && (
    <cite class="mt-3 block text-sm font-normal not-italic text-zinc-500 dark:text-zinc-400">
      — {author}
    </cite>
  )}
</blockquote>
